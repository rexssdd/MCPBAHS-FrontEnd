# Frontend environment variables
# ─────────────────────────────────────────────────────────────────
# Set ALL three to your actual backend server URL before deploying.
# They intentionally point to the same server but are named
# differently because three service files each reference a different
# variable (VITE_API_BASE_URL, VITE_BACKEND_URL, VITE_API_URL).
# ─────────────────────────────────────────────────────────────────

# Used by: loginApi.js, AuthContext.jsx, most services, Config/teacherconfig.js
VITE_API_BASE_URL=http://localhost:8001/api

# Used by: Sidebar.jsx  (derives base by stripping /api/v1 from VITE_API_BASE_URL,
#          but reads VITE_BACKEND_URL first if present)
VITE_BACKEND_URL=http://localhost:8001

# Used by: services/Registrar/registrarEnrollmentService.js
VITE_API_URL=http://localhost:8001

# Use backend /api/auth/login when VITE_API_BASE_URL is set.
VITE_USE_API_AUTH=true

# Keep local default users available if the backend is offline during dev.
# MUST be false (or absent) in production.
VITE_ALLOW_AUTH_FALLBACK=false
