# ─────────────────────────────────────────────────────────────────
# Frontend environment variables — copy to .env and fill in values
# ─────────────────────────────────────────────────────────────────
# Set ALL three to your production backend URL (same value).
# These are baked into the bundle at build time by Vite.
# Set them in Vercel → Project Settings → Environment Variables.

# Your Laravel backend URL (no trailing slash)
VITE_API_BASE_URL=https://your-backend.up.railway.app/api
VITE_BACKEND_URL=https://your-backend.up.railway.app
VITE_API_URL=https://your-backend.up.railway.app

# Auth settings — must be true in production
VITE_USE_API_AUTH=true

# MUST be false in production (removes local fallback credentials)
VITE_ALLOW_AUTH_FALLBACK=false
